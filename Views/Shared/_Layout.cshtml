<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BookStore</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark fixed-top px-4" style="background: rgba(15, 12, 41, 0.8); backdrop-filter: blur(10px); border-bottom: 1px solid var(--glass-border);">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold fs-3" asp-controller="Home" asp-action="Index" style="font-family: 'Playfair Display', serif;">
                    <span style="color: var(--accent-crimson)">SD1</span> Books
                </a>
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav ms-auto align-items-center">
                        <li class="nav-item px-2"><a class="nav-link" asp-controller="Home" asp-action="Index">Collection</a></li>
                        <li class="nav-item px-2"><a class="nav-link" asp-controller="Transaction" asp-action="History">History</a></li>
                        <li class="nav-item px-2">
                            <a class="nav-link d-flex align-items-center gap-2" asp-controller="Account" asp-action="Profile">
                                <div class="bg-danger rounded-circle d-flex align-items-center justify-content-center" style="width:32px; height:32px; font-size:14px;">J</div>
                                <span>Profile</span>
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main role="main" class="container" style="padding-top: 100px;">
        @RenderBody()
    </main>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script>
            $(document).ready(function() {
                $('main').addClass('animate__animated animate__fadeIn');
            
                $('a').not('[target="_blank"]').click(function(e) {
                    if(this.host === window.location.host && !this.href.includes('#')) {
                        e.preventDefault();
                        let url = this.href;
                        $('main').removeClass('animate__fadeIn').addClass('animate__fadeOut');
                        setTimeout(() => window.location.href = url, 300);
                    }
                });
            });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>