<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BookStore</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
</head>
<body class="main-bg" style="background-color: #0f0c29; min-height: 100vh;">
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark border-bottom border-white border-opacity-10 py-3">
            <div class="container">
                <a class="navbar-brand d-flex align-items-center" asp-controller="Home" asp-action="Index">
                    <img src="~/images/logo.png" width="35" height="35" class="me-2" alt="Logo" asp-append-version="true">
                    <span class="fw-bold fs-4 text-white">BookStore</span>
                </a>
                
                @{
                    var currentAction = ViewContext.RouteData.Values["Action"]?.ToString();
                    // Links only appear if user is logged in AND NOT on the login page
                    bool shouldShowLinks = User.Identity.IsAuthenticated && currentAction != "Login";
                }

                @if (shouldShowLinks)
                {
                    <div class="collapse navbar-collapse justify-content-center">
                        <ul class="navbar-nav gap-5">
                            <li class="nav-item">
                                <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Home" ? "text-white fw-bold" : "text-white-50")"
                                   asp-controller="Home" asp-action="Index">Home</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link @(currentAction == "Profile" ? "text-white fw-bold" : "text-white-50")"
                                   asp-controller="Account" asp-action="Profile">Profile</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Transaction" ? "text-white fw-bold" : "text-white-50")"
                                   asp-controller="Transaction" asp-action="History">Transaction History</a>
                            </li>
                        </ul>
                    </div>

                    <div class="d-flex align-items-center">
                        <div class="d-flex align-items-center me-3 text-white">
                            <span class="badge rounded-circle bg-danger me-2" style="width: 32px; height: 32px; display: flex; align-items: center; justify-content: center; font-weight: bold;">
                                J
                            </span>
                            <span class="small fw-medium d-none d-md-inline">Justine Domagtoy</span>
                        </div>
                        <a href="/Account/Logout" class="btn btn-outline-light rounded-pill px-4 btn-sm" style="border-color: rgba(255,255,255,0.3);">
                            Logout
                        </a>
                    </div>
                }
            </div>
        </nav>
    </header>

    <main role="main">
        @RenderBody()
    </main>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>