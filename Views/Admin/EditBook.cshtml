@model BookStoreApp.Models.Book
@{
    ViewData["Title"] = "Edit Book";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <a href="/Admin/Books" class="btn btn-sm btn-outline-secondary mb-3">
            <i class="bi bi-arrow-left me-1"></i>Back to Books
        </a>

        <div class="card">
            <div class="card-body p-4">
                <h3 class="mb-1" style="font-family:'Playfair Display',serif;">
                    <i class="bi bi-pencil-square me-2" style="color:#e94560;"></i>Edit Book
                </h3>
                <p class="text-muted mb-4 small">Update the details for this book.</p>

                <form method="post" action="/Admin/EditBook/@Model.Id">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <input type="hidden" asp-for="Id" />

                    <div class="mb-3">
                        <label asp-for="Title" class="form-label fw-semibold"></label>
                        <input asp-for="Title" class="form-control"
                               style="border-radius:10px; border:2px solid #e8e8e8; padding:0.75rem 1rem;" />
                        <span asp-validation-for="Title" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Author" class="form-label fw-semibold"></label>
                        <input asp-for="Author" class="form-control"
                               style="border-radius:10px; border:2px solid #e8e8e8; padding:0.75rem 1rem;" />
                        <span asp-validation-for="Author" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Price" class="form-label fw-semibold"></label>
                        <div class="input-group">
                            <span class="input-group-text" style="border-radius:10px 0 0 10px; border:2px solid #e8e8e8; border-right:0;">₱</span>
                            <input asp-for="Price" class="form-control" type="number" step="0.01" min="0"
                                   style="border-radius:0 10px 10px 0; border:2px solid #e8e8e8; border-left:0; padding:0.75rem 1rem;" />
                        </div>
                        <span asp-validation-for="Price" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Stock" class="form-label fw-semibold"></label>
                        <input asp-for="Stock" class="form-control" type="number" min="0"
                               style="border-radius:10px; border:2px solid #e8e8e8; padding:0.75rem 1rem;" />
                        <span asp-validation-for="Stock" class="text-danger small"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-accent px-4">
                            <i class="bi bi-check-lg me-2"></i>Save Changes
                        </button>
                        <a href="/Admin/Books" class="btn btn-outline-secondary px-4">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
