@model IEnumerable<BookStoreApp.Models.Book>
@{
    ViewData["Title"] = "Manage Books";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <a href="/Admin/Index" class="btn btn-sm btn-outline-secondary mb-2">
            <i class="bi bi-arrow-left me-1"></i>Back to Panel
        </a>
        <h3 class="mb-0" style="font-family:'Playfair Display',serif;">
            <i class="bi bi-book me-2" style="color:#e94560;"></i>Book Catalogue
        </h3>
    </div>
    <a href="/Admin/CreateBook" class="btn btn-accent px-4">
        <i class="bi bi-plus-lg me-2"></i>Add New Book
    </a>
</div>

<!-- Search bar -->
<div class="mb-3">
    <form method="get" action="/Admin/Books">
        <div class="input-group" style="max-width:380px;">
            <input type="text" name="search" value="@ViewBag.Search" class="form-control"
                   placeholder="Search title or author…"
                   style="border-radius:10px 0 0 10px; border:2px solid #e8e8e8;" />
            <button class="btn btn-accent" type="submit" style="border-radius:0 10px 10px 0;">
                <i class="bi bi-search"></i>
            </button>
        </div>
    </form>
</div>

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead style="background:#1a1a2e; color:white;">
                    <tr>
                        <th class="ps-4" style="border-radius:16px 0 0 0;">#</th>
                        <th>Title</th>
                        <th>Author</th>
                        <th>Price</th>
                        <th>Stock</th>
                        <th class="pe-4 text-center" style="border-radius:0 16px 0 0;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var book in Model)
                    {
                        <tr>
                            <td class="ps-4 text-muted small">@book.Id</td>
                            <td class="fw-semibold">@book.Title</td>
                            <td class="text-muted">@book.Author</td>
                            <td style="color:#e94560; font-weight:700;">₱@book.Price.ToString("N2")</td>
                            <td>
                                @if (book.Stock == 0)
                                {
                                    <span class="badge rounded-pill px-3" style="background:#e94560;">Out of Stock</span>
                                }
                                else if (book.Stock <= 5)
                                {
                                    <span class="badge rounded-pill px-3" style="background:#f5a623; color:#333;">@book.Stock left</span>
                                }
                                else
                                {
                                    <span class="badge rounded-pill px-3 bg-success">@book.Stock</span>
                                }
                            </td>
                            <td class="pe-4 text-center">
                                <a href="/Admin/EditBook/@book.Id" class="btn btn-sm btn-outline-primary me-1">
                                    <i class="bi bi-pencil-square me-1"></i>Edit
                                </a>
                                <form method="post" action="/Admin/DeleteBook/@book.Id"
                                      style="display:inline;"
                                      onsubmit="return confirm('Delete \'@book.Title\'? This cannot be undone.');">
                                    <button type="submit" class="btn btn-sm btn-outline-danger">
                                        <i class="bi bi-trash me-1"></i>Delete
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center text-muted py-5">
                                <i class="bi bi-book" style="font-size:2rem;"></i>
                                <p class="mt-2 mb-0">No books found.</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
