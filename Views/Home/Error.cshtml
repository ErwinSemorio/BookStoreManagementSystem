@model BookStoreApp.Models.ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<div class="text-center py-5">
    <div style="font-size:5rem;">⚠️</div>
    <h1 class="mt-3" style="font-family:'Playfair Display',serif;">Something went wrong</h1>
    @if (Model.ShowRequestId)
    {
        <p class="text-muted small">Request ID: <code>@Model.RequestId</code></p>
    }
    <a href="/Books/Index" class="btn btn-accent mt-3 px-4">
        <i class="bi bi-house me-2"></i>Go Home
    </a>
</div>
