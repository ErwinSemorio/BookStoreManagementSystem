@model BookStoreApp.Models.Book
@{
    ViewData["Title"] = Model.Title;
}

<div class="container py-5">
    <!-- Back Button -->
    <div class="mb-5">
        <a href="/Books/Index" class="btn btn-glass rounded-pill px-5 py-2 fw-bold text-decoration-none fade-in-up">
            <i class="bi bi-arrow-left me-2"></i>Back to Collection
        </a>
    </div>

    <div class="row g-5">
        <!-- BOOK IMAGE & ACTION BUTTONS -->
        <div class="col-lg-5">
            <div class="glass-card p-5 text-center position-sticky" style="top: 120px; height: fit-content;" data-hover>
                <div class="book-hero-image mb-5 position-relative mx-auto overflow-hidden rounded-4 shadow-lg" 
                     style="width: 320px; height: 420px; background: linear-gradient(135deg, #1e3a8a, #3b82f6);">
                    
                    @{
                        string imageUrl = Model.Title switch
                        {
                            "Harry Potter and the Sorcerer's Stone" => "/images/books/harry.jpg",
                            "The Alchemist" => "/images/books/alchemist.jpg",
                            "Rich Dad Poor Dad" => "/images/books/richdad.jpg",
                            "To Kill a Mockingbird" => "/images/books/mockingbird.jpg",
                            "The Great Gatsby" => "/images/books/gatsby.jpg",
                            "1984" => "/images/books/1984.jpg",
                            "Atomic Habits" => "/images/books/atomic.jpg",
                            "The 48 Laws of Power" => "/images/books/48laws.jpg",
                            _ => !string.IsNullOrEmpty(Model.CoverImage) ? $"/images/books/{Model.CoverImage}" : ""
                        };
                    }

                    @if (!string.IsNullOrEmpty(imageUrl))
                    {
                        <img src="@imageUrl" alt="@Model.Title" 
                             class="w-100 h-100 position-absolute" 
                             style="object-fit: cover; transition: transform 0.5s ease;" />
                    }
                    else
                    {
                        <div class="d-flex flex-column align-items-center justify-content-center h-100 px-4">
                            <i class="bi bi-book display-1 text-white opacity-25 mb-3"></i>
                            <p class="text-white opacity-50 mb-0 text-center">Cover image not available</p>
                        </div>
                    }

                    @if (Model.Stock > 0)
                    {
                        <div class="position-absolute top-4 end-4">
                            <span class="badge @(Model.Stock < 5 ? "bg-warning text-dark shadow" : "bg-success shadow") px-4 py-2 rounded-pill fs-6 fw-bold">
                                @(Model.Stock < 5 ? $"⚡ {Model.Stock} left" : "✅ In Stock")
                            </span>
                        </div>
                    }
                </div>

                <!-- QUICK ACTIONS -->
                <div class="d-grid gap-3">
                    <form asp-controller="Transaction" asp-action="Confirm" method="get" class="d-grid">
                        <input type="hidden" name="id" value="@Model.Id" />
                        <input type="hidden" name="quantity" value="1" />
                        <button type="submit" class="btn btn-premium fs-5 py-4 rounded-3 fw-bold shadow-lg" data-hover>
                            <i class="bi bi-lightning-charge me-2"></i>
                            Buy Now - ₱@Model.Price.ToString("N2")
                        </button>
                    </form>
                    
                    <button class="btn btn-glass fs-6 py-3 rounded-3 fw-bold" data-hover>
                        <i class="bi bi-heart me-2"></i>Add to Wishlist
                    </button>
                </div>
            </div>
        </div>

        <!-- BOOK CONTENT -->
        <div class="col-lg-7">
            <!-- HEADER -->
            <div class="glass-card p-5 mb-5 fade-in-up" data-hover>
                <div class="d-flex align-items-start justify-content-between flex-wrap gap-4 mb-4">
                    <div class="flex-grow-1">
                        <h1 class="display-4 fw-bold mb-3 lh-1 text-white" style="font-family: 'Playfair Display', serif;">
                            @Model.Title
                        </h1>
                        <h3 class="text-accent fw-bold mb-3 fs-3">@Model.Author</h3>
                        
                        <!-- RATINGS -->
                        <div class="d-flex align-items-center gap-3 mb-4">
                            <div class="star-rating d-flex">
                                <i class="bi bi-star-fill text-warning fs-5"></i>
                                <i class="bi bi-star-fill text-warning fs-5"></i>
                                <i class="bi bi-star-fill text-warning fs-5"></i>
                                <i class="bi bi-star-fill text-warning fs-5"></i>
                                <i class="bi bi-star-half text-warning fs-5"></i>
                            </div>
                            <span class="text-secondary fs-5 fw-bold">4.8 (2,847)</span>
                        </div>

                        <!-- PRICE & STOCK -->
                        <div class="d-flex align-items-center gap-4">
                            <div>
                                <small class="text-secondary text-uppercase fw-bold d-block mb-1">Price</small>
                                <h2 class="text-accent fw-bold mb-0 display-6">₱@Model.Price.ToString("N2")</h2>
                            </div>
                            <div class="vr mx-4 opacity-25" style="width: 1px; height: 60px;"></div>
                            <div>
                                <small class="text-secondary text-uppercase fw-bold d-block mb-1">Stock</small>
                                <span class="badge @(Model.Stock < 5 ? "bg-warning text-dark fs-6 px-4 py-2 fw-bold" : "bg-success fs-6 px-4 py-2 fw-bold")">
                                    @Model.Stock available
                                </span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- DESCRIPTION & DETAILS -->
            <div class="glass-card p-5 fade-in-up" data-hover>
                <!-- TABS -->
                <ul class="nav nav-tabs mb-5 border-0" style="background: rgba(255,255,255,0.05); border-radius: 20px; padding: 6px; backdrop-filter: blur(20px);">
                    <li class="nav-item w-50 text-center">
                        <a class="nav-link active px-0 py-3 fw-bold fs-5 text-white rounded-3" data-bs-toggle="tab" href="#description">
                            <i class="bi bi-card-text me-2"></i>Description
                        </a>
                    </li>
                    <li class="nav-item w-50 text-center">
                        <a class="nav-link px-0 py-3 fw-bold fs-5 text-secondary" data-bs-toggle="tab" href="#details">
                            <i class="bi bi-info-circle me-2"></i>Details
                        </a>
                    </li>
                </ul>

                <!-- TAB CONTENT -->
                <div class="tab-content">
                    <!-- DESCRIPTION -->
                    <div class="tab-pane fade show active" id="description">
                        <div class="lead text-secondary mb-5 lh-lg" style="line-height: 1.8;">
                            @if (!string.IsNullOrEmpty(Model.Description))
                            {
                                @Html.Raw(Model.Description)
                            }
                            else
                            {
                                <p>Discover the captivating story of <strong>@Model.Title</strong> by <em>@Model.Author</em>. This timeless classic explores profound themes through unforgettable characters and masterful storytelling. Perfect for readers seeking both entertainment and enlightenment.</p>
                            }
                        </div>

                        <!-- QUICK SPECS -->
                        <div class="row g-4">
                            <div class="col-md-4">
                                <div class="d-flex align-items-center p-4 rounded-3" style="background: rgba(255,255,255,0.05);">
                                    <div class="bg-success bg-opacity-20 rounded-circle p-3 me-3">
                                        <i class="bi bi-file-earmark-text text-success fs-4"></i>
                                    </div>
                                    <div>
                                        <h6 class="fw-bold text-white mb-1">Pages</h6>
                                        <span class="text-secondary">352 pages</span>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="d-flex align-items-center p-4 rounded-3" style="background: rgba(255,255,255,0.05);">
                                    <div class="bg-accent bg-opacity-20 rounded-circle p-3 me-3">
                                        <i class="bi bi-calendar3 text-accent fs-4"></i>
                                    </div>
                                    <div>
                                        <h6 class="fw-bold text-white mb-1">Published</h6>
                                        <span class="text-secondary">@(Model.PublishedDate?.ToString("MMM yyyy") ?? "2023")</span>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="d-flex align-items-center p-4 rounded-3" style="background: rgba(255,255,255,0.05);">
                                    <div class="bg-primary bg-opacity-20 rounded-circle p-3 me-3">
                                        <i class="bi bi-translate text-primary fs-4"></i>
                                    </div>
                                    <div>
                                        <h6 class="fw-bold text-white mb-1">Language</h6>
                                        <span class="text-secondary">English</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- DETAILS -->
                    <div class="tab-pane fade" id="details">
                        <div class="row g-4">
                            <div class="col-md-6">
                                <strong class="text-white fs-5 d-block mb-2">ISBN</strong>
                                <span class="text-secondary fs-5">@(Model.ISBN ?? "N/A")</span>
                            </div>
                            <div class="col-md-6">
                                <strong class="text-white fs-5 d-block mb-2">Category</strong>
                                <span class="text-secondary fs-5">Literature</span>
                            </div>
                            <div class="col-md-6">
                                <strong class="text-white fs-5 d-block mb-2">Publisher</strong>
                                <span class="text-secondary fs-5">@(Model.Publisher ?? "Penguin Random House")</span>
                            </div>
                            <div class="col-md-6">
                                <strong class="text-white fs-5 d-block mb-2">Format</strong>
                                <span class="text-secondary fs-5">Paperback</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
.book-hero-image:hover img { 
    transform: scale(1.05) !important; 
}
.nav-tabs .nav-link.active {
    background: linear-gradient(135deg, var(--accent), #ff6b9d) !important;
    box-shadow: 0 8px 25px rgba(233,69,96,0.3);
    transform: translateY(-2px);
}
.nav-tabs .nav-link {
    transition: all 0.3s ease;
    border: none !important;
}
.nav-tabs .nav-link:hover:not(.active) {
    background: rgba(233,69,96,0.15) !important;
    color: var(--text-primary) !important;
}
.star-rating i { font-size: 1.3rem; margin-right: 2px; }
</style>