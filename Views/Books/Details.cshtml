@model BookStoreApp.Models.Book
@{
    ViewData["Title"] = Model.Title;
}

<div class="container py-5">
    <div class="mb-4">
        <a href="/Books/Index" class="btn btn-outline-light rounded-pill px-4">
            <i class="bi bi-arrow-left me-2"></i> Back to Books
        </a>
    </div>

    <div class="card-glass overflow-hidden p-0 border-0 shadow-lg">
        <div class="row g-0">
            <div class="col-md-5 position-relative" style="background: rgba(0,0,0,0.2); min-height: 450px; display: flex; align-items: center; justify-content: center;">
                @{
                    // Ensure these filenames match what is actually in your wwwroot/images/books/ folder
                    string imageUrl = Model.Title switch
                    {
                        "Harry Potter and the Sorcerer's Stone" => "/images/books/harry.jpg",
                        "The Alchemist" => "/images/books/alchemist.jpg",
                        "Rich Dad Poor Dad" => "/images/books/richdad.jpg",
                        "To Kill a Mockingbird" => "/images/books/mockingbird.jpg",
                        "The Great Gatsby" => "/images/books/gatsby.jpg",
                        "1984" => "/images/books/1984.jpg",
                        "Atomic Habits" => "/images/books/atomic.jpg",
                        "The 48 Laws of Power" => "/images/books/48laws.jpg",
                        _ => ""
                    };
                }

                @if (!string.IsNullOrEmpty(imageUrl))
                {
                    <img src="@imageUrl" alt="@Model.Title" style="width: 100%; height: 100%; object-fit: cover;" />
                }
                else
                {
                    <div class="text-center opacity-25">
                        <i class="bi bi-book-half text-white" style="font-size: 6rem;"></i>
                        <p class="text-white mt-2">Image Not Found</p>
                    </div>
                }

                <div class="position-absolute bottom-0 start-50 translate-middle-x mb-4">
                    <span class="badge bg-success px-4 py-2 rounded-pill shadow">In Stock</span>
                </div>
            </div>

            <div class="col-md-7 bg-white p-5">
                <h1 class="fw-bold text-dark mb-1" style="font-family: 'Playfair Display', serif;">@Model.Title</h1>
                <p class="text-muted fs-5 mb-4">by @Model.Author</p>
                
                <hr class="my-4">

                <div class="mb-4">
                    <small class="text-uppercase text-muted fw-bold d-block mb-1">Price</small>
                    <h2 class="text-danger fw-bold">₱@Model.Price.ToString("N2")</h2>
                </div>

                <div class="mb-4">
                    <small class="text-uppercase text-muted fw-bold d-block mb-1">Availability</small>
                    <div class="d-flex align-items-center">
                        <i class="bi bi-check-circle-fill me-2 text-success"></i>
                        <span class="fw-bold text-dark">@Model.Stock copies available</span>
                    </div>
                </div>

                <!-- ✅ UPDATED FORM: Routes to Confirm page (GET) for balance review -->
                <form asp-controller="Transaction" asp-action="Confirm" method="get">
                    <input type="hidden" name="id" value="@Model.Id" />
                    
                    <div class="mb-4">
                        <small class="text-uppercase text-muted fw-bold d-block mb-2">Select Quantity</small>
                        <div class="d-flex align-items-center gap-3">
                            <input type="number" name="quantity" value="1" min="1" max="@Model.Stock"
                                   class="form-control text-dark border-secondary bg-light fw-bold"
                                   style="width: 100px; height: 45px;" />
                            <span class="text-muted small">Max: @Model.Stock</span>
                        </div>
                    </div>

                    <button type="submit" class="btn btn-primary-custom w-100 py-3 rounded-pill fw-bold shadow">
                        <i class="bi bi-cart-plus me-2"></i> Confirm Purchase
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>