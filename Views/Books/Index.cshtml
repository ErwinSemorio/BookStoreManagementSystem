@model BookStoreApp.Models.DashboardViewModel
@{
    ViewData["Title"] = "Book Collection";
}

<div class="container py-5">
    <!-- HERO SECTION -->
    <div class="row g-4 mb-5">
        <div class="col-lg-8">
            <div class="hero-section glass-card p-5 position-relative overflow-hidden fade-in-up" data-hover>
                <div class="position-relative z-index-1">
                    <span class="badge bg-white bg-opacity-20 px-4 py-2 fs-6 fw-bold mb-4">🔥 Editor's Choice</span>
                    <h1 class="display-4 fw-bold mb-3 text-white lh-1">Discover Your<br>Next Favorite Read</h1>
                    <p class="lead text-white opacity-90 mb-0">Curated collection of timeless stories and modern masterpieces</p>
                </div>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="glass-card h-100 p-5 text-center fade-in-up" data-hover style="background: linear-gradient(135deg, #8b5cf6, #a78bfa);">
                <i class="bi bi-book-half display-4 opacity-75 mb-4"></i>
                <h3 class="fw-bold mb-3 text-white">Daily Inspiration</h3>
                <p class="opacity-90 mb-4" style="line-height: 1.6;">"The reading of all good books is like conversation with the finest minds of past centuries."</p>
                <div class="text-center">
                    <small class="opacity-75 fw-bold text-uppercase ls-3">— René Descartes</small>
                </div>
            </div>
        </div>
    </div>

    <!-- WALLET BANNER -->
    <div class="glass-card p-4 mb-5 fade-in-up" style="background: linear-gradient(135deg, rgba(16,185,129,0.2), rgba(52,211,153,0.1));">
        <div class="d-flex align-items-center justify-content-between flex-wrap gap-3">
            <div class="d-flex align-items-center gap-3">
                <i class="bi bi-wallet2 fs-3 text-success"></i>
                <div>
                    <small class="text-secondary d-block">Your Wallet Balance</small>
                    <span class="fw-bold fs-4 text-white">₱@Model.WalletBalance.ToString("N2")</span>
                </div>
            </div>
            <div class="d-flex align-items-center gap-3">
                <div class="text-center">
                    <small class="text-secondary d-block">Total Orders</small>
                    <span class="fw-bold fs-5 text-white">@Model.TotalOrders</span>
                </div>
                <a href="/Account/ReloadWallet" class="btn btn-success rounded-pill px-4">
                    <i class="bi bi-plus-circle me-2"></i>Add Funds
                </a>
            </div>
        </div>
    </div>

    <!-- SEARCH & FILTERS -->
    <div class="row align-items-center mb-5">
        <div class="col-lg-7 mb-4 mb-lg-0">
            <h1 class="display-4 fw-bold mb-2 fade-in-up">The Collection</h1>
            <p class="text-secondary lead mb-0 fade-in-up">
                @if (!string.IsNullOrEmpty(ViewData["CurrentFilter"]?.ToString()))
                {
                    <span>Showing <strong>@Model.Books.Count</strong> results for "<mark class="bg-warning bg-opacity-20">@ViewData["CurrentFilter"]</mark>"</span>
                }
                else
                {
                    <span><strong>@Model.Books.Count</strong> stories waiting for you</span>
                }
            </p>
        </div>
        <div class="col-lg-5">
            <form asp-action="Index" method="get" class="search-hero fade-in-up">
                <div class="d-flex">
                    <input type="text" name="searchString" value="@ViewData["CurrentFilter"]"
                           class="form-control border-0 bg-transparent text-white ps-4 py-3"
                           placeholder="Search by title, author..." style="outline: none;">
                    <button type="submit" class="btn btn-premium px-4 me-2">
                        <i class="bi bi-search"></i>
                    </button>
                    @if (!string.IsNullOrEmpty(ViewData["CurrentFilter"]?.ToString()))
                    {
                        <a asp-action="Index" class="btn btn-glass px-3">
                            <i class="bi bi-x"></i>
                        </a>
                    }
                </div>
            </form>
        </div>
    </div>

    <!-- BOOKS GRID -->
    <div class="row g-4">
        @if (!Model.Books.Any())
        {
            <div class="col-12 text-center py-8 fade-in-up">
                <i class="bi bi-inbox display-1 text-secondary mb-4"></i>
                <h2 class="text-white mb-3">No books found</h2>
                <p class="text-secondary lead mb-4">Try different keywords or check back later</p>
                <a asp-action="Index" class="btn btn-premium px-5">Browse All Books</a>
            </div>
        }
        else
        {
            @for (int i = 0; i < Model.Books.Count; i++)
            {
                var book = Model.Books[i];
                <div class="col-xl-3 col-lg-4 col-md-6 fade-in-up" style="animation-delay: @(i * 0.1)s;">
                    <div class="glass-card book-card h-100 p-0">
                        <div class="card-img-wrapper">
                            @if (!string.IsNullOrEmpty(book.CoverImage))
                            {
                                <img src="/images/books/@book.CoverImage" class="w-100 h-100" alt="@book.Title" />
                            }
                            else
                            {
                                <i class="bi bi-book display-4 text-white opacity-25"></i>
                            }
                            @if (book.Stock < 5 && book.Stock > 0)
                            {
                                <span class="stock-badge animate__animated animate__pulse animate__infinite">Low Stock</span>
                            }
                        </div>
                        <div class="card-body text-center pt-0">
                            <h5 class="fw-bold mb-2 text-truncate" style="font-size: 1.1rem;">@book.Title</h5>
                            <p class="text-secondary small mb-3">@book.Author</p>
                            <div class="d-flex justify-content-center align-items-center mb-4">
                                <span class="h4 fw-bold text-glow mb-0">₱@book.Price.ToString("N0")</span>
                            </div>
                            <a asp-controller="Books" asp-action="Details" asp-route-id="@book.Id"
                               class="btn btn-premium w-100 mb-2" data-hover>View Details</a>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>