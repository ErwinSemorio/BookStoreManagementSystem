@model IEnumerable<BookStoreApp.Models.Book>
@{
    ViewData["Title"] = "Browse Books";
}



<!-- Page Header -->
<div class="d-flex align-items-center justify-content-between mb-4 flex-wrap gap-3">
    <div>
        <h2 style="font-family:'Playfair Display',serif; font-weight:700; margin:0;">
            📚 Browse Books
        </h2>
        <p class="text-muted mb-0">Find your next great read</p>
    </div>

    @if (ViewBag.IsAdmin != null && ViewBag.IsAdmin)
    {
        <p>
            <a asp-action="Create" class="btn btn-success">Create New Book</a>
        </p>
    }

    <!-- Search Bar -->
    <form method="get" action="/Books/Index" class="d-flex gap-2" style="min-width:300px;">
        <div class="input-group">
            <span class="input-group-text bg-white border-end-0">
                <i class="bi bi-search text-muted"></i>
            </span>
            <input type="text" name="search" class="form-control border-start-0 ps-0"
                   placeholder="Search by title or author..."
                   value="@ViewBag.Search"
                   style="border-radius:0 10px 10px 0; border:2px solid #e8e8e8; border-left:none;" />
        </div>
        <button type="submit" class="btn btn-accent px-3">Search</button>
        @if (!string.IsNullOrEmpty(ViewBag.Search as string))
        {
            <a href="/Books/Index" class="btn btn-outline-secondary">Clear</a>
        }
    </form>
</div>

<!-- Search Result Info -->
@if (!string.IsNullOrEmpty(ViewBag.Search as string))
{
    <div class="alert py-2 mb-3" style="background:#fff3f5; border:1px solid #f5c6cb; border-radius:10px; color:#721c24;">
        <i class="bi bi-funnel me-2"></i>
        Showing results for <strong>"@ViewBag.Search"</strong> — @Model.Count() book(s) found.
        <a href="/Books/Index" class="ms-2 text-decoration-none" style="color:#e94560;">✕ Clear</a>
    </div>
}

<!-- Books Grid -->
@if (!Model.Any())
{
    <div class="text-center py-5">
        <div style="font-size:4rem;">📭</div>
        <h4 class="text-muted mt-3">No books found</h4>
        <p class="text-muted">Try a different search term.</p>
        <a href="/Books/Index" class="btn btn-accent mt-2">View All Books</a>
    </div>
}
else
{
    <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4">
        @foreach (var book in Model)
        {
            <div class="col">
                <div class="card h-100" style="border-radius:16px; overflow:hidden;">
                    <!-- Book Cover Placeholder -->
                    <div style="height:160px; background:linear-gradient(135deg, #1a1a2e 0%, #16213e 60%, #e94560 100%);
                        display:flex; align-items:center; justify-content:center; position:relative;">
                        <span style="font-size:3.5rem;">📖</span>
                        @if (book.Stock == 0)
                        {
                            <span class="position-absolute top-0 end-0 m-2 badge"
                                  style="background:#e94560; border-radius:8px; font-size:0.7rem;">Out of Stock</span>
                        }
                        else if (book.Stock <= 5)
                        {
                            <span class="position-absolute top-0 end-0 m-2 badge"
                                  style="background:#f5a623; border-radius:8px; font-size:0.7rem;">Low Stock</span>
                        }
                    </div>

                    <div class="card-body d-flex flex-column p-3">
                        <h6 class="fw-bold mb-1 lh-sm" style="font-family:'Playfair Display',serif; font-size:0.95rem;">
                            @book.Title
                        </h6>
                        <p class="text-muted small mb-2">
                            <i class="bi bi-person me-1"></i>@book.Author
                        </p>
                        <div class="mt-auto">
                            <div class="d-flex align-items-center justify-content-between mb-2">
                                <span class="fw-bold" style="color:#e94560; font-size:1.1rem;">
                                    ₱@book.Price.ToString("N2")
                                </span>
                                <small class="text-muted">
                                    <i class="bi bi-boxes me-1"></i>@book.Stock left
                                </small>
                            </div>
                            <a href="/Books/Details/@book.Id"
                                   class="btn btn-accent btn-sm w-100">
                                <i class="bi bi-eye me-1"></i>View Details
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
