@model IEnumerable<BookStoreApp.Models.Transaction>
@{
    ViewData["Title"] = "History";
    var user = ViewBag.User as BookStoreApp.Models.Users;
}

<div class="container py-5">
    <!-- 1. Header Stats -->
    <div class="row g-4 mb-4">
        <div class="col-md-5">
            <div class="wallet-card h-100 d-flex flex-column justify-content-center">
                <small class="text-white text-opacity-75 text-uppercase fw-bold">Available Balance</small>
                <h2 class="text-white fw-bold my-2">₱@(user?.WalletBalance?.ToString("N2") ?? "0.00")</h2>
                <div class="d-flex gap-2 mt-3">
                    <a href="/Account/ReloadWallet" class="btn btn-light btn-sm fw-bold text-primary"><i class="bi bi-plus-circle me-1"></i>Deposit</a>
                    <button class="btn btn-outline-light btn-sm border-0">Withdraw</button>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 p-4 d-flex align-items-center justify-content-center">
                <div class="text-center">
                    <i class="bi bi-receipt text-primary display-6 mb-2"></i>
                    <h4 class="text-white mb-0">142 Items</h4>
                    <small class="text-secondary">Total Transactions</small>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card h-100 p-4 d-flex align-items-center justify-content-center">
                <div class="text-center">
                    <i class="bi bi-box-seam text-warning display-6 mb-2"></i>
                    <h4 class="text-white mb-0">3 Orders</h4>
                    <small class="text-secondary">Pending Verification</small>
                </div>
            </div>
        </div>
    </div>

    <!-- 2. Table -->
    <div class="card overflow-hidden">
        <div class="p-4 border-bottom border-secondary border-opacity-25 d-flex justify-content-between align-items-center">
            <h5 class="text-white mb-0">Transaction History</h5>
            <div class="btn-group">
                <button class="btn btn-sm btn-outline-custom"><i class="bi bi-filter"></i> Filter</button>
                <button class="btn btn-sm btn-outline-custom"><i class="bi bi-download"></i> Export</button>
            </div>
        </div>
        <div class="table-responsive">
            <table class="table table-dark table-hover mb-0">
                <thead>
                    <tr>
                        <th>Book Name</th>
                        <th>Date Purchased</th>
                        <th>Status</th>
                        <th class="text-end">Amount</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr><td colspan="4" class="text-center py-5 text-secondary">No transactions found.</td></tr>
                    }
                    else
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <img src="/images/books/@(item.Book?.CoverImage ?? "default.jpg")" class="rounded me-3" style="width: 40px; height: 50px; object-fit: cover;" />
                                        <div>
                                            <div class="text-white fw-bold small">@item.Book?.Title</div>
                                            <small class="text-secondary">@item.Book?.Author</small>
                                        </div>
                                    </div>
                                </td>
                                <td class="text-secondary">@item.TransactionDate.ToString("MMM dd, yyyy")</td>
                                <td>
                                    @if (item.Status == "Completed")
                                    {
                                        <span class="badge bg-success bg-opacity-25 text-success border border-success border-opacity-25">COMPLETED</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning bg-opacity-25 text-warning border border-warning border-opacity-25">PROCESSING</span>
                                    }
                                </td>
                                <td class="text-end fw-bold text-white">-₱@item.TotalAmount.ToString("N2")</td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>