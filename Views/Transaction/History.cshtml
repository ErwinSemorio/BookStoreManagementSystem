@model IEnumerable<BookStoreApp.Models.Transaction>
@{
    ViewData["Title"] = "Transaction History";
    var user = ViewBag.User as BookStoreApp.Models.Users;
}

<div class="container py-5">
    <!-- DASHBOARD STATS -->
    <div class="row g-4 mb-5">
        <div class="col-lg-5">
            <div class="wallet-card glass-card h-100 p-5 position-relative overflow-hidden fade-in-up">
                <div class="position-relative z-1">
                    <small class="text-white text-opacity-75 text-uppercase fw-bold d-block mb-2">Available Balance</small>
                    <h1 class="text-white fw-bold mb-4 lh-1">₱@(user?.WalletBalance?.ToString("N2") ?? "0.00")</h1>
                    <div class="d-flex gap-2">
                        <a href="/Account/ReloadWallet" class="btn btn-light rounded-pill px-4 py-2 fw-bold">
                            <i class="bi bi-plus-circle me-2"></i>Add Funds
                        </a>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-3 col-md-6">
            <div class="glass-card h-100 p-5 text-center fade-in-up" data-hover>
                <i class="bi bi-receipt display-4 text-accent mb-3 opacity-75"></i>
                <h3 class="fw-bold text-white mb-1">@Model.Count()</h3>
                <small class="text-secondary fw-semibold">Total Purchases</small>
            </div>
        </div>
        <div class="col-lg-4 col-md-6">
            <div class="glass-card h-100 p-5 text-center fade-in-up" data-hover>
                <i class="bi bi-clock-history display-4 text-warning mb-3 opacity-75"></i>
                <h3 class="fw-bold text-white mb-1">@Model.Count(t => t.Status != "Completed")</h3>
                <small class="text-secondary fw-semibold">Processing</small>
            </div>
        </div>
    </div>

    <!-- TRANSACTIONS TABLE -->
    <div class="glass-card overflow-hidden fade-in-up">
        <div class="p-5 border-bottom" style="border-color: var(--glass-border);">
            <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
                <div>
                    <h2 class="fw-bold mb-1 text-white">Transaction History</h2>
                    <p class="text-secondary mb-0">All your book purchases</p>
                </div>
                <div class="d-flex gap-2">
                    <button class="btn btn-glass px-4">
                        <i class="bi bi-funnel me-2"></i>Filter
                    </button>
                    <button class="btn btn-glass px-4">
                        <i class="bi bi-download me-2"></i>Export
                    </button>
                </div>
            </div>
        </div>
        
        <div class="table-responsive">
            <table class="table table-dark mb-0">
                <thead>
                    <tr>
                        <th>Book</th>
                        <th>Date</th>
                        <th>Status</th>
                        <th class="text-end">Amount</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="4" class="text-center py-8">
                                <i class="bi bi-receipt-cutoff display-3 text-secondary mb-4"></i>
                                <h4 class="text-white mb-2">No transactions yet</h4>
                                <p class="text-secondary lead mb-4">Your purchase history will appear here</p>
                                <a asp-controller="Books" asp-action="Index" class="btn btn-premium px-5">Browse Books</a>
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var item in Model)
                        {
                            <tr class="table-row-hover">
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="bg-glass rounded-3 p-2 me-3 d-flex align-items-center justify-content-center" style="width: 50px; height: 60px;">
                                            @if (!string.IsNullOrEmpty(item.Book?.CoverImage))
                                            {
                                                <img src="/images/books/@item.Book.CoverImage" class="w-100 h-100 rounded-2" style="object-fit: cover;" />
                                            }
                                            else
                                            {
                                                <i class="bi bi-book fs-6 opacity-50"></i>
                                            }
                                        </div>
                                        <div>
                                            <div class="fw-bold text-white small">@item.Book?.Title</div>
                                            <small class="text-secondary">@item.Book?.Author</small>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <div>@item.TransactionDate.ToString("MMM dd")</div>
                                    <small class="text-secondary">@item.TransactionDate.ToString("HH:mm")</small>
                                </td>
                                <td>
                                    @if (item.Status == "Completed")
                                    {
                                        <span class="badge bg-success px-3 py-2 fw-bold fs-6">✓ Completed</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning px-3 py-2 fw-bold fs-6 animate__pulse animate__infinite">⏳ Processing</span>
                                    }
                                </td>
                                <td class="text-end">
                                    <div class="fw-bold h5 text-danger mb-0">-₱@item.TotalAmount.ToString("N2")</div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    .table-row-hover:hover {
        background: rgba(233,69,96,0.1) !important;
        transform: scale(1.01);
    }
</style>