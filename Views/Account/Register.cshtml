@{
    ViewData["Title"] = "Register";
}

<div class="login-wrapper">
    <div class="register-card fade-in-up">

        <!-- LOGO -->
        <div class="text-center mb-4">
            <a asp-controller="Books" asp-action="Index" class="login-logo">
                📚 Book<span>Store</span>
            </a>
            <p class="text-secondary mt-2 mb-0" style="font-size:0.95rem;">
                Create your account and start reading
            </p>
        </div>

        <!-- DIVIDER -->
        <div class="login-divider mb-4"></div>

        <!-- SERVER ERROR -->
        @if (ViewBag.Error != null)
        {
            <div class="reg-alert reg-alert-error mb-4">
                <i class="bi bi-exclamation-circle-fill me-2"></i>@ViewBag.Error
            </div>
        }

        <form method="post" action="/Account/Register"
              enctype="multipart/form-data"
              autocomplete="off"
              onsubmit="return validateForm()">

            <input type="text"     style="display:none" />
            <input type="password" style="display:none" />

            <div class="row g-3">

                <!-- FULL NAME -->
                <div class="col-12">
                    <label class="login-label">
                        <i class="bi bi-person me-1"></i>Full Name
                    </label>
                    <input type="text" name="name" id="regName"
                           class="form-control login-input"
                           placeholder="e.g. Juan dela Cruz"
                           autocomplete="off" required />
                    <small id="nameMsg" class="field-msg"></small>
                </div>

                <!-- EMAIL -->
                <div class="col-12">
                    <label class="login-label">
                        <i class="bi bi-envelope me-1"></i>Email Address
                    </label>
                    <input type="email" name="email" id="regEmail"
                           class="form-control login-input"
                           placeholder="you@example.com"
                           autocomplete="off"
                           oninput="validateEmail()"
                           required />
                    <small id="emailMsg" class="field-msg"></small>
                </div>

                <!-- PASSWORD -->
                <div class="col-md-6">
                    <label class="login-label">
                        <i class="bi bi-lock me-1"></i>Password
                    </label>
                    <div class="position-relative">
                        <input type="password" name="password" id="regPassword"
                               class="form-control login-input pe-5"
                               placeholder="••••••••"
                               autocomplete="new-password"
                               oninput="checkStrength(this.value); checkMatch();"
                               required />
                        <button type="button" class="pwd-toggle"
                                onclick="togglePass('regPassword','eyeReg')">
                            <i id="eyeReg" class="bi bi-eye text-secondary"></i>
                        </button>
                    </div>
                    <!-- Strength bar -->
                    <div class="strength-bar mt-2">
                        <div id="strengthFill" class="strength-fill"></div>
                    </div>
                    <small id="strengthText" class="field-msg"></small>
                </div>

                <!-- CONFIRM PASSWORD -->
                <div class="col-md-6">
                    <label class="login-label">
                        <i class="bi bi-lock-fill me-1"></i>Confirm Password
                    </label>
                    <div class="position-relative">
                        <input type="password" name="confirmPassword" id="regConfirm"
                               class="form-control login-input pe-5"
                               placeholder="••••••••"
                               autocomplete="new-password"
                               oninput="checkMatch()"
                               required />
                        <button type="button" class="pwd-toggle"
                                onclick="togglePass('regConfirm','eyeConfirm')">
                            <i id="eyeConfirm" class="bi bi-eye text-secondary"></i>
                        </button>
                    </div>
                    <small id="matchText" class="field-msg"></small>
                </div>

                <!-- PROFILE PICTURE -->
                <div class="col-12">
                    <label class="login-label">
                        <i class="bi bi-image me-1"></i>Profile Picture
                        <span class="text-secondary fw-normal ms-1">(optional)</span>
                    </label>
                    <div class="upload-area" id="uploadArea"
                         onclick="document.getElementById('profileInput').click()">
                        <div id="uploadPlaceholder">
                            <i class="bi bi-cloud-arrow-up fs-2 text-secondary mb-2 d-block"></i>
                            <p class="text-secondary mb-1" style="font-size:0.9rem;">
                                Click to upload photo
                            </p>
                            <small class="text-secondary" style="font-size:0.78rem;">
                                JPG, PNG, GIF, WebP — max 5MB
                            </small>
                        </div>
                        <div id="uploadPreview" style="display:none;" class="text-center">
                            <img id="imgPreview"
                                 class="rounded-circle mb-2"
                                 style="width:80px;height:80px;object-fit:cover;
                                        border:3px solid var(--accent);"
                                 src="#" alt="Preview" />
                            <p id="imgName" class="text-secondary mb-0"
                               style="font-size:0.82rem;"></p>
                            <button type="button"
                                    class="btn btn-sm mt-2"
                                    style="font-size:0.78rem;color:var(--accent);
                                           background:none;border:1px solid var(--accent);
                                           border-radius:8px;"
                                    onclick="clearImage(event)">
                                Remove
                            </button>
                        </div>
                    </div>
                    <input type="file" name="profileImage" id="profileInput"
                           hidden accept="image/*"
                           onchange="previewImage(this)" />
                </div>

                <!-- TERMS -->
                <div class="col-12">
                    <div class="d-flex align-items-start gap-2">
                        <input type="checkbox" id="terms"
                               class="form-check-input mt-1"
                               style="background:var(--bg-glass);
                                      border-color:var(--glass-border);
                                      min-width:16px;"
                               required />
                        <label for="terms" class="text-secondary"
                               style="font-size:0.85rem;cursor:pointer;">
                            I agree to the
                            <span style="color:var(--accent);font-weight:600;">
                                Terms of Service
                            </span>
                            and
                            <span style="color:var(--accent);font-weight:600;">
                                Privacy Policy
                            </span>
                        </label>
                    </div>
                </div>

                <!-- SUBMIT -->
                <div class="col-12 mt-2">
                    <button type="submit" id="submitBtn"
                            class="btn btn-premium w-100 py-3 fw-bold">
                        <i class="bi bi-person-plus me-2"></i>Create Account
                    </button>
                </div>

            </div>
        </form>

        <!-- LOGIN LINK -->
        <div class="text-center mt-4">
            <span class="text-secondary" style="font-size:0.9rem;">
                Already have an account?
            </span>
            <a asp-controller="Account" asp-action="Login"
               class="ms-1 fw-bold text-decoration-none"
               style="color:var(--accent);font-size:0.9rem;">
                Sign In
            </a>
        </div>

    </div>
</div>

<style>
    .login-wrapper {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 2rem 1rem;
    }

    .register-card {
        width: 100%;
        max-width: 580px;
        background: rgba(255,255,255,0.05);
        backdrop-filter: blur(24px) saturate(180%);
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 32px;
        padding: 3rem 2.5rem;
        box-shadow: 0 24px 60px rgba(0,0,0,0.4);
    }

    /* ✅ FIXED logo — white + red accent, no gradient */
    .login-logo {
        font-family: 'Playfair Display', serif;
        font-size: 36px;
        font-weight: 700;
        color: #ffffff;
        text-decoration: none;
        letter-spacing: -0.5px;
        display: inline-flex;
        align-items: center;
        gap: 4px;
    }
    .login-logo:hover { color: #ffffff; text-decoration: none; opacity: 0.9; }
    .login-logo span  { color: #e94560; }

    .login-divider {
        height: 1px;
        background: rgba(255,255,255,0.08);
        border-radius: 2px;
    }

    .login-label {
        display: block;
        font-size: 0.78rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.8px;
        color: var(--text-secondary);
        margin-bottom: 0.5rem;
    }

    .login-input {
        background: rgba(255,255,255,0.06) !important;
        border: 1px solid rgba(255,255,255,0.08) !important;
        border-radius: 14px !important;
        color: #ffffff !important;
        padding: 14px 18px !important;
        font-size: 0.95rem;
        transition: border-color 0.25s, box-shadow 0.25s, transform 0.2s;
    }
    .login-input::placeholder { color: rgba(255,255,255,0.2) !important; }
    .login-input:focus {
        background: rgba(255,255,255,0.09) !important;
        border-color: var(--accent) !important;
        box-shadow: 0 0 0 4px rgba(233,69,96,0.2) !important;
        transform: scale(1.01);
        outline: none !important;
    }
    .login-input.is-valid   { border-color: #10b981 !important; box-shadow: 0 0 0 3px rgba(16,185,129,0.15) !important; }
    .login-input.is-invalid { border-color: #e94560 !important; box-shadow: 0 0 0 3px rgba(233,69,96,0.15) !important; }

    /* Field messages */
    .field-msg { font-size: 0.75rem; display: block; margin-top: 4px; min-height: 16px; }

    /* Password toggle */
    .pwd-toggle {
        position: absolute; right: 14px; top: 50%;
        transform: translateY(-50%);
        background: none; border: none; padding: 0;
        cursor: pointer; z-index: 10;
    }

    /* Strength bar */
    .strength-bar {
        height: 4px;
        background: rgba(255,255,255,0.08);
        border-radius: 4px;
        overflow: hidden;
    }
    .strength-fill {
        height: 100%; width: 0%;
        border-radius: 4px;
        transition: width 0.4s ease, background 0.4s ease;
    }

    /* Upload area */
    .upload-area {
        border: 2px dashed rgba(255,255,255,0.12);
        border-radius: 16px;
        padding: 1.5rem;
        text-align: center;
        cursor: pointer;
        transition: border-color 0.25s, background 0.25s;
        background: rgba(255,255,255,0.03);
    }
    .upload-area:hover {
        border-color: var(--accent);
        background: rgba(233,69,96,0.05);
    }

    /* Alert */
    .reg-alert {
        border-radius: 14px;
        padding: 0.9rem 1.2rem;
        font-size: 0.9rem;
        display: flex;
        align-items: center;
    }
    .reg-alert-error {
        background: rgba(233,69,96,0.1);
        border: 1px solid rgba(233,69,96,0.3);
        color: #e94560;
    }
    .reg-alert-success {
        background: rgba(16,185,129,0.1);
        border: 1px solid rgba(16,185,129,0.25);
        color: #10b981;
    }

    .form-check-input:checked {
        background-color: var(--accent) !important;
        border-color: var(--accent) !important;
    }

    @@media (max-width: 576px) {
        .register-card { padding: 2rem 1.5rem; }
        .login-logo    { font-size: 28px; }
    }
</style>

<script>
    // ── Toggle password visibility ────────────────────────────────────────────
    function togglePass(fieldId, iconId) {
        const field = document.getElementById(fieldId);
        const icon  = document.getElementById(iconId);
        field.type  = field.type === 'password' ? 'text' : 'password';
        icon.classList.toggle('bi-eye');
        icon.classList.toggle('bi-eye-slash');
    }

    // ── Email format validation (client-side) ─────────────────────────────────
    function validateEmail() {
        const input = document.getElementById('regEmail');
        const msg   = document.getElementById('emailMsg');
        const val   = input.value.trim();
        const re    = /^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/;

        if (val === '') {
            input.classList.remove('is-valid', 'is-invalid');
            msg.textContent = '';
            return true;
        }

        if (!re.test(val)) {
            input.classList.add('is-invalid');
            input.classList.remove('is-valid');
            msg.textContent  = '✗ Please enter a valid email address';
            msg.style.color  = '#e94560';
            return false;
        }

        input.classList.add('is-valid');
        input.classList.remove('is-invalid');
        msg.textContent = '✓ Looks good!';
        msg.style.color = '#10b981';
        return true;
    }

    // ── Password strength ─────────────────────────────────────────────────────
    function checkStrength(val) {
        const fill = document.getElementById('strengthFill');
        const text = document.getElementById('strengthText');
        let score  = 0;

        if (val.length >= 6)               score++;
        if (val.length >= 10)              score++;
        if (/[A-Z]/.test(val))             score++;
        if (/[0-9]/.test(val))             score++;
        if (/[^A-Za-z0-9]/.test(val))     score++;

        const levels = [
            { pct: '0%',   color: 'transparent', label: '' },
            { pct: '25%',  color: '#e94560',      label: 'Weak' },
            { pct: '50%',  color: '#f97316',      label: 'Fair' },
            { pct: '75%',  color: '#eab308',      label: 'Good' },
            { pct: '90%',  color: '#10b981',      label: 'Strong' },
            { pct: '100%', color: '#10b981',      label: '💪 Very Strong' },
        ];

        const level          = levels[Math.min(score, 5)];
        fill.style.width     = level.pct;
        fill.style.background= level.color;
        text.textContent     = level.label;
        text.style.color     = level.color;
    }

    // ── Password match check ──────────────────────────────────────────────────
    function checkMatch() {
        const pwd     = document.getElementById('regPassword').value;
        const confirm = document.getElementById('regConfirm');
        const msg     = document.getElementById('matchText');

        if (confirm.value === '') {
            confirm.classList.remove('is-valid', 'is-invalid');
            msg.textContent = '';
            return true;
        }

        if (pwd === confirm.value) {
            confirm.classList.add('is-valid');
            confirm.classList.remove('is-invalid');
            msg.textContent = '✓ Passwords match';
            msg.style.color = '#10b981';
            return true;
        } else {
            confirm.classList.add('is-invalid');
            confirm.classList.remove('is-valid');
            msg.textContent = '✗ Passwords do not match';
            msg.style.color = '#e94560';
            return false;
        }
    }

    // ── Full form validation before submit ────────────────────────────────────
    function validateForm() {
        const name     = document.getElementById('regName').value.trim();
        const email    = document.getElementById('regEmail').value.trim();
        const password = document.getElementById('regPassword').value;
        const confirm  = document.getElementById('regConfirm').value;
        const terms    = document.getElementById('terms').checked;

        // Name check
        if (name === '') {
            showFormError('Full name is required.');
            return false;
        }

        // Email check
        if (!validateEmail()) {
            showFormError('Please enter a valid email address.');
            return false;
        }

        // Password length
        if (password.length < 6) {
            showFormError('Password must be at least 6 characters.');
            document.getElementById('regPassword').classList.add('is-invalid');
            return false;
        }

        // Password match — BLOCKS SUBMIT if mismatch
        if (password !== confirm) {
            showFormError('Passwords do not match. Please check and try again.');
            document.getElementById('regConfirm').classList.add('is-invalid');
            document.getElementById('regConfirm').focus();
            return false;
        }

        // Terms
        if (!terms) {
            showFormError('You must agree to the Terms of Service to continue.');
            return false;
        }

        return true; // all good — allow submit
    }

    function showFormError(msg) {
        // Remove old error if exists
        const old = document.getElementById('formErrorBox');
        if (old) old.remove();

        const box = document.createElement('div');
        box.id = 'formErrorBox';
        box.className = 'reg-alert reg-alert-error mb-3';
        box.innerHTML = '<i class="bi bi-exclamation-circle-fill me-2"></i>' + msg;

        const form = document.querySelector('form');
        form.insertBefore(box, form.firstChild);
        box.scrollIntoView({ behavior: 'smooth', block: 'center' });
    }

    // ── Image preview ─────────────────────────────────────────────────────────
    function previewImage(input) {
        if (input.files && input.files[0]) {
            const file = input.files[0];
            if (file.size > 5 * 1024 * 1024) {
                alert('File too large — max 5MB');
                input.value = '';
                return;
            }
            const reader = new FileReader();
            reader.onload = e => {
                document.getElementById('imgPreview').src          = e.target.result;
                document.getElementById('imgName').textContent     = file.name;
                document.getElementById('uploadPlaceholder').style.display = 'none';
                document.getElementById('uploadPreview').style.display     = 'block';
            };
            reader.readAsDataURL(file);
        }
    }

    // ── Clear image ───────────────────────────────────────────────────────────
    function clearImage(e) {
        e.stopPropagation();
        document.getElementById('profileInput').value              = '';
        document.getElementById('imgPreview').src                  = '#';
        document.getElementById('imgName').textContent             = '';
        document.getElementById('uploadPlaceholder').style.display = 'block';
        document.getElementById('uploadPreview').style.display     = 'none';
    }
</script>