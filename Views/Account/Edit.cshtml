@model BookStoreApp.Models.Users
@{
    ViewData["Title"] = "Edit Profile";
}

<style>
    :root {
        --bg-body: #0d1117;
        --bg-card: #161b22;
        --bg-input: #0d1117;
        --border-color: #30363d;
        --text-primary: #ffffff;
        --text-secondary: #8b949e;
        --accent-blue: #2f81f7;
        --accent-green: #238636;
    }

    body {
        background-color: var(--bg-body);
        color: var(--text-primary);
        font-family: 'Inter', -apple-system, sans-serif;
    }

    /* Card Styles */
    .edit-card {
        background: var(--bg-card);
        border: 1px solid var(--border-color);
        border-radius: 12px;
        overflow: hidden;
    }

    /* Avatar Section */
    .avatar-section {
        background: rgba(255,255,255,0.02);
        border-right: 1px solid var(--border-color);
        padding: 2rem;
        text-align: center;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
    }

    .avatar-circle {
        width: 120px;
        height: 120px;
        border-radius: 50%;
        object-fit: cover;
        border: 3px solid var(--border-color);
        margin-bottom: 1rem;
        background: var(--bg-input);
    }

    .avatar-btn {
        background: transparent;
        border: 1px solid var(--border-color);
        color: var(--text-secondary);
        border-radius: 6px;
        padding: 0.4rem 1rem;
        font-size: 0.85rem;
        cursor: pointer;
        transition: all 0.2s;
    }

        .avatar-btn:hover {
            border-color: var(--text-secondary);
            color: var(--text-primary);
        }

    /* Form Section */
    .form-section {
        padding: 2.5rem;
    }

    .section-title {
        font-size: 1rem;
        font-weight: 600;
        color: var(--text-primary);
        margin-bottom: 1.5rem;
        padding-bottom: 0.5rem;
        border-bottom: 1px solid var(--border-color);
    }

    .form-label {
        font-size: 0.85rem;
        color: var(--text-secondary);
        margin-bottom: 0.4rem;
    }

    .form-control {
        background: var(--bg-input);
        border: 1px solid var(--border-color);
        color: var(--text-primary) !important;
        border-radius: 6px;
        padding: 0.6rem 0.8rem;
        font-size: 0.9rem;
    }

        .form-control:focus {
            background: var(--bg-input);
            border-color: var(--accent-blue);
            box-shadow: 0 0 0 3px rgba(47, 129, 247, 0.2);
        }

    /* Buttons */
    .btn-save {
        background: var(--accent-blue);
        color: white !important;
        border: none;
        border-radius: 6px;
        padding: 0.6rem 1.5rem;
        font-weight: 600;
    }

        .btn-save:hover {
            background: #58a6ff;
        }

    .btn-cancel {
        background: transparent;
        color: var(--text-secondary) !important;
        border: 1px solid var(--border-color);
        border-radius: 6px;
        padding: 0.6rem 1.5rem;
    }

        .btn-cancel:hover {
            background: rgba(255,255,255,0.05);
            color: var(--text-primary) !important;
        }
    
    /* Responsive */
    @@media (max-width: 768px) {
        .avatar-section {
            border-right: none;
            border-bottom: 1px solid var(--border-color);
        }
    }
</style>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            
            <div class="mb-4">
                <h2 class="fw-bold text-white mb-1">Edit Profile</h2>
                <p class="text-secondary small">Update your academic credentials and personal information.</p>
            </div>

            <form method="post" action="/Account/Edit" enctype="multipart/form-data">
                <div class="edit-card">
                    <div class="row g-0">
                        
                        <!-- Left: Avatar -->
                        <div class="col-md-4">
                            <div class="avatar-section">
                                @if (!string.IsNullOrEmpty(Model.ProfileImage))
                                {
                                    <img id="avatarPreview" src="/images/@Model.ProfileImage" class="avatar-circle" />
                                }
                                else
                                {
                                    <div id="avatarFallback" class="avatar-circle d-flex align-items-center justify-content-center" style="font-size: 3rem; color: var(--accent-blue); font-weight: bold;">
                                        @Model.Name[0]
                                    </div>
                                    <img id="avatarPreview" src="#" class="avatar-circle" style="display:none;" />
                                }

                                <label class="avatar-btn" for="profileInput">
                                    <i class="bi bi-camera me-1"></i> Change Picture
                                </label>
                                <input type="file" name="profileImage" id="profileInput" class="d-none" accept="image/*" onchange="previewImage(this)" />
                                <small class="text-secondary mt-2" style="font-size: 0.75rem;">PNG or JPG, max 5MB</small>
                            </div>
                        </div>

                        <!-- Right: Form -->
                        <div class="col-md-8">
                            <div class="form-section">
                                
                                <!-- Personal Info -->
                                <div class="mb-5">
                                    <h5 class="section-title">Personal Information</h5>
                                    <div class="mb-3">
                                        <label class="form-label">Full Name</label>
                                        <input type="text" name="name" value="@Model.Name" class="form-control" required />
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label">Email Address</label>
                                        <input type="email" name="email" value="@Model.Email" class="form-control" required />
                                    </div>
                                </div>

                                <!-- Security -->
                                <div class="mb-4">
                                    <h5 class="section-title">Security</h5>
                                    <div class="row g-3">
                                        <div class="col-md-6">
                                            <label class="form-label">New Password</label>
                                            <input type="password" name="newPassword" class="form-control" placeholder="••••••••" />
                                            <small class="text-secondary" style="font-size: 0.75rem;">Leave blank to keep current password</small>
                                        </div>
                                        <div class="col-md-6">
                                            <label class="form-label">Confirm Password</label>
                                            <input type="password" class="form-control" placeholder="••••••••" />
                                        </div>
                                    </div>
                                </div>

                                <!-- Actions -->
                                <div class="d-flex gap-3 justify-content-end mt-5">
                                    <a href="/Account/Profile" class="btn btn-cancel text-decoration-none">Cancel</a>
                                    <button type="submit" class="btn btn-save">Save Changes</button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    function previewImage(input) {
        const preview = document.getElementById('avatarPreview');
        const fallback = document.getElementById('avatarFallback');
        if (input.files && input.files[0]) {
            const reader = new FileReader();
            reader.onload = e => {
                preview.src = e.target.result;
                preview.style.display = 'block';
                if (fallback) fallback.style.display = 'none';
            };
            reader.readAsDataURL(input.files[0]);
        }
    }
</script>