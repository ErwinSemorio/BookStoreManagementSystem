@{
    ViewData["Title"] = "Login";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login - BookStore</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=DM+Sans:wght@400;500&display=swap" rel="stylesheet" />
    <style>
            body {
                font-family: 'DM Sans', sans-serif;
                background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
                min-height: 100vh;
                display: flex;
                align-items: center;
            }
            .auth-card {
                background: white;
                border-radius: 24px;
                box-shadow: 0 24px 64px rgba(0,0,0,0.3);
                overflow: hidden;
                max-width: 440px;
                width: 100%;
                margin: auto;
            }
            .auth-header {
                background: linear-gradient(135deg, #1a1a2e, #e94560);
                padding: 2.5rem 2rem 2rem;
                text-align: center;
                color: white;
            }
            .auth-header h1 { font-family: 'Playfair Display', serif; font-size: 2rem; margin: 0; }
            .auth-header p { opacity: 0.8; margin: 0.5rem 0 0; }
            .auth-body { padding: 2rem; }
            .form-label { font-weight: 600; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.5px; color: #555; }
            .form-control {
                border-radius: 10px;
                padding: 0.75rem 1rem;
                border: 2px solid #e8e8e8;
                transition: border-color 0.2s;
            }
            .form-control:focus { border-color: #e94560; box-shadow: 0 0 0 3px rgba(233,69,96,0.1); }
            .btn-login {
                background: linear-gradient(135deg, #e94560, #c73652);
                color: white;
                border: none;
                border-radius: 10px;
                padding: 0.75rem;
                font-weight: 700;
                font-size: 1rem;
                width: 100%;
                transition: transform 0.1s, box-shadow 0.2s;
            }
            .btn-login:hover { transform: translateY(-1px); box-shadow: 0 6px 20px rgba(233,69,96,0.4); color: white; }
            .book-icon { font-size: 3rem; display: block; margin-bottom: 0.5rem; }
    </style>
</head>
<body>
    <div class="container">
        <div class="auth-card mx-auto">
            <div class="auth-header">
                <span class="book-icon">📚</span>
                <h1>BookStore</h1>
                <p>Sign in to your account</p>
            </div>
            <div class="auth-body">
                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger rounded-3 py-2">
                        <i class="bi bi-exclamation-circle me-2"></i>@ViewBag.Error
                    </div>
                }
                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success rounded-3 py-2">
                        <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
                    </div>
                }

                <form method="post" action="/Account/Login">
                    <div class="mb-3">
                        <label class="form-label">Email Address</label>
                        <input type="email" name="email" class="form-control" placeholder="you@example.com" required />
                    </div>
                    <div class="mb-4">
                        <label class="form-label">Password</label>
                        <input type="password" name="password" class="form-control" placeholder="••••••••" required />
                    </div>
                    <button type="submit" class="btn-login mb-3">
                        <i class="bi bi-box-arrow-in-right me-2"></i>Sign In
                    </button>
                </form>

                <div class="text-center">
                    <span class="text-muted small">Don't have an account?</span>
                    <a href="/Account/Register" class="ms-1 fw-bold text-decoration-none" style="color:#e94560">Register</a>
                </div>
            </div>
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
