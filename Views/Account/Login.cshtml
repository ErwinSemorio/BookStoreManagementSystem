@{
    ViewData["Title"] = "Login";
}

<div class="container d-flex align-items-center justify-content-center" style="min-height: 80vh;">
    <div class="col-md-6 col-lg-5">
        <div class="card bg-dark text-white p-5 shadow-lg border-0" style="border-radius: 20px; background-color: rgba(30, 30, 50, 0.9) !important;">
            <div class="text-center mb-4">
                <img src="~/images/logo.png" width="60" class="mb-3" alt="Logo" asp-append-version="true">
                <h2 class="fw-bold" style="font-family:'Playfair Display', serif;">Welcome Back</h2>
                <p class="text-white-50">Sign in to continue to BookStore</p>
            </div>

            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger border-0 bg-danger bg-opacity-10 text-danger small">
                    <i class="bi bi-exclamation-circle me-2"></i>@ViewBag.Error
                </div>
            }

            <form method="post" action="/Account/Login">
                <div class="mb-4">
                    <label class="form-label small text-white-50 fw-bold">EMAIL ADDRESS</label>
                    <input type="email" name="email" class="form-control bg-light text-dark py-3 border-0 shadow-none"
                           placeholder="you@example.com" style="border-radius: 10px;" required />
                </div>
                
                <div class="mb-4">
                    <label class="form-label small text-white-50 fw-bold">PASSWORD</label>
                    <input type="password" name="password" class="form-control bg-light text-dark py-3 border-0 shadow-none"
                           placeholder="••••••••" style="border-radius: 10px;" required />
                </div>

                <button type="submit" class="btn btn-danger w-100 py-3 fw-bold shadow-sm" style="background-color: #e94560; border-radius: 10px; border: none;">
                    <i class="bi bi-box-arrow-in-right me-2"></i>Sign In
                </button>
            </form>

            <div class="text-center mt-4">
                <span class="text-white-50 small">New to BookStore?</span>
                <a href="/Account/Register" class="ms-1 fw-bold text-decoration-none" style="color: #e94560">
                    Create Account
                </a>
            </div>
        </div>
    </div>
</div>