@model BookStoreApp.Models.Users
@{
    ViewData["Title"] = "Profile Dashboard";
    decimal wallet     = Model.WalletBalance ?? 0m;
    var transactions   = ViewBag.Transactions as List<BookStoreApp.Models.Transaction> ?? new();
    var wishlist       = ViewBag.Wishlist     as List<BookStoreApp.Models.Wishlist>     ?? new();
    int booksOwned     = ViewBag.BooksOwned   is int bo ? bo : transactions.Sum(t => t.Quantity);
    var recentActivity = transactions.Take(5).ToList();
}

<div class="container py-5">

    <!-- PROFILE HEADER -->
    <div class="glass-card p-5 mb-5 position-relative overflow-hidden fade-in-up" data-hover>
        <div class="row align-items-center">
            <div class="col-md-8">
                <div class="d-flex align-items-center gap-4 mb-4 mb-md-0">
                    <div class="avatar-lg glass-card d-flex align-items-center justify-content-center"
                         style="background:linear-gradient(135deg,var(--accent),#ff6b9d);">
                        @if (!string.IsNullOrEmpty(Model.ProfileImage))
                        {
                            <img src="/images/@Model.ProfileImage"
                                 class="w-100 h-100 rounded-circle"
                                 style="object-fit:cover;" />
                        }
                        else
                        {
                            <span class="fs-3 fw-bold text-white">
                                @(Model.Name?[0].ToString() ?? "U")
                            </span>
                        }
                    </div>
                    <div>
                        <h1 class="fw-bold mb-2 text-white">@Model.Name</h1>
                        <p class="text-secondary mb-1 lead">@Model.Email</p>
                        <span class="badge px-3 py-2 fw-bold fs-6"
                              style="background:var(--accent);">@Model.Role</span>
                    </div>
                </div>
            </div>
            <div class="col-md-4 text-md-end">
                <div class="d-flex gap-3 justify-content-md-end flex-wrap">
                    <a href="/Account/Edit" class="btn btn-premium px-4">
                        <i class="bi bi-pencil me-2"></i>Edit Profile
                    </a>
                    <a href="/Transaction/History" class="btn btn-glass px-4">
                        <i class="bi bi-receipt me-2"></i>Transaction History
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- STATS ROW -->
    <div class="row g-4 mb-5">

        <!-- Wallet -->
        <div class="col-lg-4 col-md-6 fade-in-up" style="animation-delay:0.1s;">
            <div class="wallet-card glass-card h-100 p-5 text-center position-relative overflow-hidden" data-hover>
                <div class="position-relative z-1">
                    <i class="bi bi-wallet2 display-4 text-white opacity-75 mb-3"></i>
                    <small class="text-white text-opacity-75 text-uppercase fw-bold d-block mb-2">
                        Wallet Balance
                    </small>
                    <h2 class="text-white fw-bold mb-4 lh-1">₱@wallet.ToString("N2")</h2>
                    <a href="/Account/ReloadWallet"
                       class="btn btn-light rounded-pill px-4 py-2 fw-bold">
                        <i class="bi bi-plus-circle me-2"></i>Add Funds
                    </a>
                </div>
            </div>
        </div>

        <!-- Books Owned — REAL DATA -->
        <div class="col-lg-4 col-md-6 fade-in-up" style="animation-delay:0.2s;">
            <div class="glass-card h-100 p-5 text-center" data-hover>
                <i class="bi bi-book display-4 mb-3 opacity-75"
                   style="color:var(--accent);"></i>
                <small class="text-secondary text-uppercase fw-bold d-block mb-2">
                    Books Owned
                </small>
                <h3 class="fw-bold text-white mb-1">@booksOwned</h3>
                <small class="text-secondary">
                    from @transactions.Count transaction(s)
                </small>
            </div>
        </div>

        <!-- Wishlist Count -->
        <div class="col-lg-4 col-md-6 fade-in-up" style="animation-delay:0.3s;">
            <div class="glass-card h-100 p-5 text-center" data-hover
                 style="background:linear-gradient(135deg,#8b5cf6,#a78bfa);">
                <i class="bi bi-heart display-4 text-white opacity-75 mb-3"></i>
                <small class="text-white text-opacity-75 text-uppercase fw-bold d-block mb-2">
                    Wishlist
                </small>
                <h3 class="fw-bold text-white mb-1">@wishlist.Count</h3>
                <small class="text-white opacity-75">saved books</small>
            </div>
        </div>

    </div>

    <!-- ACTIVITY + WISHLIST ROW -->
    <div class="row g-4">

        <!-- Recent Activity — REAL DATA -->
        <div class="col-lg-8 fade-in-up" style="animation-delay:0.4s;">
            <div class="glass-card p-5 h-100" data-hover>
                <h3 class="fw-bold mb-4 text-white d-flex align-items-center">
                    <i class="bi bi-activity me-3" style="color:var(--accent);"></i>
                    Recent Activity
                </h3>

                @if (!recentActivity.Any())
                {
                    <div class="text-center py-4">
                        <i class="bi bi-receipt-cutoff display-4 text-secondary mb-3 d-block"></i>
                        <p class="text-secondary mb-3">No purchases yet.</p>
                        <a href="/Books/Index" class="btn btn-premium px-4">
                            Browse Books
                        </a>
                    </div>
                }
                else
                {
                    <div class="activity-list">
                        @for (int i = 0; i < recentActivity.Count; i++)
                        {
                            var t       = recentActivity[i];
                            bool isLast = i == recentActivity.Count - 1;
                            var diff    = DateTime.Now - t.TransactionDate;
                            string timeAgo;
                            if      (diff.TotalMinutes < 1)  timeAgo = "Just now";
                            else if (diff.TotalMinutes < 60) timeAgo = $"{(int)diff.TotalMinutes} min ago";
                            else if (diff.TotalHours   < 24) timeAgo = $"{(int)diff.TotalHours} hr ago";
                            else if (diff.TotalDays    < 7)  timeAgo = $"{(int)diff.TotalDays} day(s) ago";
                            else if (diff.TotalDays    < 30) timeAgo = $"{(int)(diff.TotalDays / 7)} week(s) ago";
                            else                             timeAgo = t.TransactionDate.ToString("MMM dd, yyyy");

                            <div class="activity-item py-3 @(isLast ? "" : "border-bottom")"
                                 style="border-color:var(--glass-border);">
                                <div class="row align-items-center">
                                    <div class="col-auto">
                                        <div class="rounded-circle p-3"
                                             style="background:rgba(233,69,96,0.15);">
                                            <i class="bi bi-book fs-5"
                                               style="color:var(--accent);"></i>
                                        </div>
                                    </div>
                                    <div class="col">
                                        <div class="fw-bold text-white small mb-1">
                                            Purchased "@t.Book?.Title"
                                            @if (t.Quantity > 1)
                                            {
                                                <span class="badge ms-1 px-2"
                                                      style="background:rgba(255,255,255,0.1);
                                                             color:var(--text-secondary);
                                                             font-size:0.75rem;">
                                                    x@t.Quantity
                                                </span>
                                            }
                                        </div>
                                        <small class="text-secondary">@timeAgo</small>
                                    </div>
                                    <div class="col-auto text-end">
                                        <span class="fw-bold" style="color:#e94560;">
                                            -₱@t.TotalAmount.ToString("N2")
                                        </span>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>

                    <div class="text-center mt-4">
                        <a href="/Transaction/History"
                           class="btn btn-glass px-4 py-2"
                           style="font-size:0.85rem;">
                            View All Transactions
                            <i class="bi bi-arrow-right ms-2"></i>
                        </a>
                    </div>
                }
            </div>
        </div>

        <!-- WISHLIST CARD — replaces Achievements -->
        <div class="col-lg-4 fade-in-up" style="animation-delay:0.5s;">
            <div class="glass-card p-4 h-100" data-hover>
                <h3 class="fw-bold mb-4 text-white d-flex align-items-center">
                    <i class="bi bi-heart-fill me-2" style="color:var(--accent);"></i>
                    My Wishlist
                    <span class="badge ms-2 px-2 py-1"
                          style="background:rgba(233,69,96,0.2);
                                 color:var(--accent);
                                 font-size:0.75rem;
                                 border-radius:8px;">
                        @wishlist.Count
                    </span>
                </h3>

                @if (!wishlist.Any())
                {
                    <div class="text-center py-4">
                        <i class="bi bi-heart display-3 text-secondary mb-3 d-block"></i>
                        <p class="text-secondary small mb-3">
                            No books saved yet.
                        </p>
                        <a href="/Books/Index"
                           class="btn btn-glass px-4"
                           style="font-size:0.82rem;">
                            Browse Books
                        </a>
                    </div>
                }
                else
                {
                    <div class="wishlist-list" style="max-height:420px;overflow-y:auto;">
                        @foreach (var item in wishlist)
                        {
                            <div class="wishlist-item d-flex align-items-center gap-3 py-3 border-bottom"
                                 style="border-color:var(--glass-border);">

                                <!-- Cover -->
                                <div class="rounded-3 overflow-hidden flex-shrink-0"
                                     style="width:42px;height:52px;
                                            background:linear-gradient(135deg,#1e3a8a,#3b82f6);">
                                    @if (!string.IsNullOrEmpty(item.Book?.CoverImage))
                                    {
                                        <img src="/images/books/@item.Book.CoverImage"
                                             class="w-100 h-100"
                                             style="object-fit:cover;" />
                                    }
                                    else
                                    {
                                        <div class="w-100 h-100 d-flex align-items-center justify-content-center">
                                            <i class="bi bi-book text-white opacity-50"
                                               style="font-size:0.8rem;"></i>
                                        </div>
                                    }
                                </div>

                                <!-- Info -->
                                <div class="flex-grow-1 overflow-hidden">
                                    <div class="fw-bold text-white text-truncate"
                                         style="font-size:0.85rem;">
                                        @item.Book?.Title
                                    </div>
                                    <small class="text-secondary d-block text-truncate">
                                        @item.Book?.Author
                                    </small>
                                    <small class="fw-bold" style="color:var(--accent);">
                                        ₱@item.Book?.Price.ToString("N2")
                                    </small>
                                </div>

                                <!-- Actions -->
                                <div class="d-flex flex-column gap-1 flex-shrink-0">
                                    <a asp-controller="Books"
                                       asp-action="Details"
                                       asp-route-id="@item.BookId"
                                       class="btn py-1 px-2"
                                       style="font-size:0.72rem;
                                              background:rgba(233,69,96,0.15);
                                              color:var(--accent);
                                              border:1px solid rgba(233,69,96,0.3);
                                              border-radius:8px;
                                              white-space:nowrap;">
                                        View
                                    </a>
                                    <form method="post" action="/Wishlist/Remove">
                                        <input type="hidden" name="bookId"
                                               value="@item.BookId" />
                                        <button type="submit"
                                                class="btn py-1 px-2 w-100"
                                                style="font-size:0.72rem;
                                                       background:rgba(255,255,255,0.05);
                                                       color:var(--text-secondary);
                                                       border:1px solid var(--glass-border);
                                                       border-radius:8px;">
                                            Remove
                                        </button>
                                    </form>
                                </div>

                            </div>
                        }
                    </div>

                    <div class="text-center mt-3">
                        <a href="/Books/Index"
                           class="btn btn-glass px-4 py-2"
                           style="font-size:0.82rem;">
                            <i class="bi bi-plus me-1"></i>Add More Books
                        </a>
                    </div>
                }
            </div>
        </div>

    </div>
</div>

<style>
    .activity-item { transition: all 0.2s ease; }
    .activity-item:hover {
        background: rgba(255,255,255,0.03);
        border-radius: 16px;
        transform: translateX(8px);
    }
    .wishlist-item { transition: all 0.2s ease; }
    .wishlist-item:hover {
        background: rgba(255,255,255,0.03);
        border-radius: 12px;
        padding-left: 8px !important;
    }
    .wishlist-list::-webkit-scrollbar { width: 4px; }
    .wishlist-list::-webkit-scrollbar-track { background: transparent; }
    .wishlist-list::-webkit-scrollbar-thumb {
        background: var(--glass-border);
        border-radius: 4px;
    }
    .avatar-lg { width: 90px; height: 90px; }
</style>