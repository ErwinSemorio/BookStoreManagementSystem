@model BookStoreApp.Models.Users
@{
    ViewData["Title"] = "Profile Dashboard";
    decimal wallet = Model.WalletBalance ?? 0m;
}

<div class="container py-5">
    <div class="glass-card p-5 mb-5 position-relative overflow-hidden fade-in-up" data-hover>
        <div class="row align-items-center">
            <div class="col-md-8">
                <div class="d-flex align-items-center gap-4 mb-4 mb-md-0">
                    <div class="avatar-lg glass-card d-flex align-items-center justify-content-center position-relative" style="background: linear-gradient(135deg, var(--accent), #ff6b9d);">
                        @if (!string.IsNullOrEmpty(Model.ProfileImage))
                        {
                            <img src="/images/@Model.ProfileImage" class="w-100 h-100 rounded-circle" style="object-fit: cover;" />
                        }
                        else
                        {
                            /* FIXED: Convert char? to string safely */
                            <span class="fs-3 fw-bold text-white">@(Model.Name?[0].ToString() ?? "U")</span>
                        }
                    </div>
                    <div>
                        <h1 class="fw-bold mb-2 text-white">@Model.Name</h1>
                        <p class="text-secondary mb-1 lead">@Model.Email</p>
                        <span class="badge bg-accent px-3 py-2 fw-bold fs-6">@Model.Role</span>
                    </div>
                </div>
            </div>
            <div class="col-md-4 text-md-end">
                <div class="d-flex gap-3 justify-content-md-end flex-wrap">
                    <a href="/Account/Edit" class="btn btn-premium px-4">
                        <i class="bi bi-pencil me-2"></i>Edit Profile
                    </a>
                    <a href="/Transaction/History" class="btn btn-glass px-4">
                        <i class="bi bi-receipt me-2"></i>Transaction History
                    </a>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4 mb-5">
        <div class="col-lg-4 col-md-6 fade-in-up" style="animation-delay: 0.1s;">
            <div class="wallet-card glass-card h-100 p-5 text-center position-relative overflow-hidden" data-hover>
                <div class="position-relative z-1">
                    <i class="bi bi-wallet2 display-4 text-white opacity-75 mb-3"></i>
                    <small class="text-white text-opacity-75 text-uppercase fw-bold d-block mb-2">Wallet Balance</small>
                    <h2 class="text-white fw-bold mb-4 lh-1">₱@wallet.ToString("N2")</h2>
                    <a href="/Account/ReloadWallet" class="btn btn-light rounded-pill px-4 py-2 fw-bold">
                        <i class="bi bi-plus-circle me-2"></i>Add Funds
                    </a>
                </div>
            </div>
        </div>

        <div class="col-lg-4 col-md-6 fade-in-up" style="animation-delay: 0.2s;">
            <div class="glass-card h-100 p-5 text-center" data-hover>
                <i class="bi bi-book display-4 text-accent mb-3 opacity-75"></i>
                <small class="text-secondary text-uppercase fw-bold d-block mb-2">Books Owned</small>
                <h3 class="fw-bold text-white mb-0">48</h3>
            </div>
        </div>

        <div class="col-lg-4 col-md-6 fade-in-up" style="animation-delay: 0.3s;">
            <div class="glass-card h-100 p-5 text-center" data-hover style="background: linear-gradient(135deg, #8b5cf6, #a78bfa);">
                <i class="bi bi-gem display-4 text-white opacity-75 mb-3"></i>
                <small class="text-white text-opacity-75 text-uppercase fw-bold d-block mb-2">Loyalty Points</small>
                <h3 class="fw-bold text-white mb-0">1,560</h3>
                <small class="text-white opacity-75">Gold Member</small>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-8 fade-in-up" style="animation-delay: 0.4s;">
            <div class="glass-card p-5 h-100" data-hover>
                <h3 class="fw-bold mb-4 text-white d-flex align-items-center">
                    <i class="bi bi-activity me-3 text-accent"></i>Recent Activity
                </h3>
                <div class="activity-list">
                    <div class="activity-item py-3 border-bottom" style="border-color: var(--glass-border);">
                        <div class="row align-items-center">
                            <div class="col-auto">
                                <div class="bg-accent bg-opacity-20 rounded-circle p-3">
                                    <i class="bi bi-book text-accent fs-5"></i>
                                </div>
                            </div>
                            <div class="col">
                                <div class="fw-bold text-white small mb-1">Purchased "The Great Gatsby"</div>
                                <small class="text-secondary">2 hours ago</small>
                            </div>
                            <div class="col-auto text-end">
                                <span class="text-success fw-bold">-₱250</span>
                            </div>
                        </div>
                    </div>
                    <div class="activity-item py-3 border-bottom" style="border-color: var(--glass-border);">
                        <div class="row align-items-center">
                            <div class="col-auto">
                                <div class="bg-success bg-opacity-20 rounded-circle p-3">
                                    <i class="bi bi-wallet2 text-success fs-5"></i>
                                </div>
                            </div>
                            <div class="col">
                                <div class="fw-bold text-white small mb-1">Wallet Reloaded</div>
                                <small class="text-secondary">1 day ago</small>
                            </div>
                            <div class="col-auto text-end">
                                <span class="text-success fw-bold">+₱1,000</span>
                            </div>
                        </div>
                    </div>
                    <div class="activity-item py-3" style="border-color: var(--glass-border);">
                        <div class="row align-items-center">
                            <div class="col-auto">
                                <div class="bg-warning bg-opacity-20 rounded-circle p-3">
                                    <i class="bi bi-star text-warning fs-5"></i>
                                </div>
                            </div>
                            <div class="col">
                                <div class="fw-bold text-white small mb-1">Earned Loyalty Points</div>
                                <small class="text-secondary">3 days ago</small>
                            </div>
                            <div class="col-auto text-end">
                                <span class="text-accent fw-bold">+150 pts</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4 fade-in-up" style="animation-delay: 0.5s;">
            <div class="glass-card p-5 h-100 text-center" data-hover>
                <h3 class="fw-bold mb-4 text-white">🏆 Achievements</h3>
                <div class="achievements-grid">
                    <div class="achievement-item mb-3 p-3 rounded-3 bg-glass" data-hover>
                        <i class="bi bi-bookmark-star display-6 text-warning mb-2"></i>
                        <div class="fw-bold text-white small mb-1">Bookworm</div>
                        <small class="text-secondary">25+ books</small>
                    </div>
                    <div class="achievement-item mb-3 p-3 rounded-3 bg-glass" data-hover>
                        <i class="bi bi-lightning-charge display-6 text-accent mb-2"></i>
                        <div class="fw-bold text-white small mb-1">Active Reader</div>
                        <small class="text-secondary">7 days streak</small>
                    </div>
                    <div class="achievement-item p-3 rounded-3 bg-glass" data-hover>
                        <i class="bi bi-gem display-6 text-success mb-2"></i>
                        <div class="fw-bold text-white small mb-1">Gold Member</div>
                        <small class="text-secondary">VIP Status</small>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
.activity-item:hover { background: rgba(255,255,255,0.03); border-radius: 16px; transform: translateX(8px); }
.achievement-item:hover { 
    background: rgba(233,69,96,0.1) !important; 
    border: 1px solid var(--accent) !important;
    transform: translateY(-4px) !important;
}
.avatar-lg { width: 90px; height: 90px; }
.bg-accent { background: var(--accent) !important; }
</style>