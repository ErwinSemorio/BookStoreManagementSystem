@model BookStoreApp.Models.Users
@{
    ViewData["Title"] = "My Profile";
}

<div class="row justify-content-center">
    <div class="col-md-7">
        <div class="card p-0 overflow-hidden">
            <!-- Header Banner -->
            <div style="background: linear-gradient(135deg, #1a1a2e, #e94560); height: 120px; position: relative;">
                <div style="position: absolute; bottom: -50px; left: 50%; transform: translateX(-50%);">
                    @if (!string.IsNullOrEmpty(Model.ProfileImage))
                    {
                        <img src="/images/@Model.ProfileImage"
                             style="width:100px;height:100px;border-radius:50%;object-fit:cover;border:4px solid white;box-shadow:0 4px 16px rgba(0,0,0,0.2);" />
                    }
                    else
                    {
                        <div style="width:100px;height:100px;border-radius:50%;background:#e94560;border:4px solid white;display:flex;align-items:center;justify-content:center;box-shadow:0 4px 16px rgba(0,0,0,0.2);">
                            <span style="font-size:2.5rem;color:white;font-weight:700;">@Model.Name[0].ToString().ToUpper()</span>
                        </div>
                    }
                </div>
            </div>

            <!-- Profile Info -->
            <div class="card-body text-center pt-5 mt-3">
                <h3 style="font-family:'Playfair Display',serif; font-weight:700;">@Model.Name</h3>
                <span class="badge rounded-pill px-3 py-2 mb-2"
                      style="background: @(Model.Role == "Admin" ? "#e94560" : "#1a1a2e"); color:white; font-size:0.8rem;">
                    <i class="bi bi-@(Model.Role == "Admin" ? "shield-check" : "person-check") me-1"></i>@Model.Role
                </span>
                <p class="text-muted mt-2"><i class="bi bi-envelope me-2"></i>@Model.Email</p>

                <hr class="my-3" />

                <div class="d-flex justify-content-center gap-3 flex-wrap">
                    <a href="/Account/Edit" class="btn btn-accent px-4">
                        <i class="bi bi-pencil-square me-2"></i>Edit Profile
                    </a>
                    <a href="/Transaction/History" class="btn btn-outline-secondary px-4">
                        <i class="bi bi-clock-history me-2"></i>My Orders
                    </a>
                    <a href="/Books/Index" class="btn btn-outline-secondary px-4">
                        <i class="bi bi-book me-2"></i>Browse Books
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
