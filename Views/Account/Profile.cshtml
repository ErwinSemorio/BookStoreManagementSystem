@model BookStoreApp.Models.Users
@{
    ViewData["Title"] = "Profile";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card-glass overflow-hidden text-center p-0">
                <div class="profile-banner"></div>
                
                <div class="px-4 pb-5">
                    <div class="profile-avatar-wrapper">
                        <i class="bi bi-person-circle"></i>
                    </div>

                    <h3 class="mt-3 fw-bold">@Model.Name</h3>
                    <p class="text-muted small mb-3">@Model.Email</p>
                    
                    <div class="d-flex justify-content-center gap-2 mb-4">
                        <span class="badge rounded-pill bg-danger bg-opacity-25 text-danger px-3 py-2">
                            <i class="bi bi-star-fill me-1"></i> Premium Member
                        </span>
                        <span class="badge rounded-pill bg-primary bg-opacity-25 text-info px-3 py-2">
                            Literature Major
                        </span>
                    </div>

                    <div class="row g-3 mb-5">
                        <div class="col-4">
                            <div class="p-2 rounded-4 bg-white bg-opacity-5 border border-white border-opacity-10">
                                <h4 class="mb-0 fw-bold">12</h4>
                                <small class="text-muted text-uppercase" style="font-size: 0.6rem;">Rented</small>
                            </div>
                        </div>
                        <div class="col-4">
                            <div class="p-2 rounded-4 bg-white bg-opacity-5 border border-white border-opacity-10">
                                <h4 class="mb-0 fw-bold">48</h4>
                                <small class="text-muted text-uppercase" style="font-size: 0.6rem;">Purchased</small>
                            </div>
                        </div>
                        <div class="col-4">
                            <div class="p-2 rounded-4 bg-white bg-opacity-5 border border-white border-opacity-10 text-warning">
                                <h4 class="mb-0 fw-bold">156</h4>
                                <small class="text-muted text-uppercase" style="font-size: 0.6rem;">Points</small>
                            </div>
                        </div>
                    </div>

                    <div class="d-grid gap-3 mb-4">
                        <a href="/Account/Edit" class="btn btn-primary-custom">
                            <i class="bi bi-pencil-square me-2"></i>Edit Profile
                        </a>
                        <a href="/Transaction/History" class="btn btn-outline-light rounded-pill border-opacity-25">
                            <i class="bi bi-clock-history me-2"></i>My Orders
                        </a>
                    </div>

                    <div class="row pt-4 border-top border-white border-opacity-10 text-start g-3">
                        <div class="col-6">
                            <small class="text-muted d-block mb-1">Currently Reading</small>
                            <span class="fw-bold d-block small">The Great Gatsby</span>
                            <div class="progress mt-2" style="height: 4px;">
                                <div class="progress-bar" style="width: 65%;"></div>
                            </div>
                        </div>
                        <div class="col-6">
                            <small class="text-muted d-block mb-1">Next Due Date</small>
                            <span class="fw-bold d-block small">Organic Chem Vol 2</span>
                            <span class="text-danger small" style="font-size: 0.7rem;">In 2 Days</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>