@model BookStoreApp.Models.Users
@{
    ViewData["Title"] = "Profile";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card-glass overflow-hidden text-center p-0 animate__animated animate__fadeInUp">
                <div class="profile-banner" style="background: linear-gradient(135deg, #1a1a2e, #e94560); height: 120px;"></div>
                
                <div class="px-4 pb-5">
                    <div class="profile-avatar-wrapper" style="margin-top: -50px;">
                        @if (!string.IsNullOrEmpty(Model.ProfileImage))
                        {
                            <img src="/images/@Model.ProfileImage" class="rounded-circle border border-4 border-dark shadow-lg" style="width:110px; height:110px; object-fit:cover;" />
                        }
                        else
                        {
                            <div class="bg-danger rounded-circle border border-4 border-dark shadow-lg d-flex align-items-center justify-content-center mx-auto" style="width:110px; height:110px;">
                                <span class="display-6 fw-bold text-white">@Model.Name[0]</span>
                            </div>
                        }
                    </div>

                    <h3 class="mt-3 fw-bold">@Model.Name</h3>
                    <p class="text-muted small mb-3">@Model.Email</p>
                    
                    <div class="d-flex justify-content-center gap-2 mb-4">
                        <!-- ✅ FIXED: Proper nullable decimal formatting -->
                        <span class="badge rounded-pill bg-danger bg-opacity-25 text-danger px-3 py-2 border border-danger border-opacity-25">
                            <i class="bi bi-wallet2 me-1"></i> ₱@(Model.WalletBalance?.ToString("N2") ?? "0.00")
                        </span>
                        <span class="badge rounded-pill bg-primary bg-opacity-25 text-info px-3 py-2 border border-info border-opacity-25">
                            Premium Member
                        </span>
                    </div>

                    <div class="row g-3 mb-5">
                        <div class="col-4">
                            <div class="p-2 rounded-4 bg-white bg-opacity-5 border border-white border-opacity-10">
                                <h4 class="mb-0 fw-bold">48</h4>
                                <small class="text-muted text-uppercase" style="font-size: 0.6rem;">Books</small>
                            </div>
                        </div>
                        <div class="col-4">
                            <div class="p-2 rounded-4 bg-white bg-opacity-5 border border-white border-opacity-10">
                                <h4 class="mb-0 fw-bold">12</h4>
                                <small class="text-muted text-uppercase" style="font-size: 0.6rem;">Rented</small>
                            </div>
                        </div>
                        <div class="col-4">
                            <div class="p-2 rounded-4 bg-white bg-opacity-5 border border-white border-opacity-10 text-warning">
                                <h4 class="mb-0 fw-bold">156</h4>
                                <small class="text-muted text-uppercase" style="font-size: 0.6rem;">Points</small>
                            </div>
                        </div>
                    </div>

                    <div class="d-grid gap-3 mb-4">
                        <a href="/Account/Edit" class="btn btn-primary-custom py-2">
                            <i class="bi bi-pencil-square me-2"></i>Update Profile
                        </a>
                        <a href="/Account/ReloadWallet" class="btn btn-outline-success rounded-pill border-opacity-25 py-2">
                            <i class="bi bi-plus-circle me-2"></i>Reload Wallet
                        </a>
                        <a href="/Transaction/History" class="btn btn-outline-light rounded-pill border-opacity-25 py-2">
                            <i class="bi bi-clock-history me-2"></i>Order History
                        </a>
                    </div>

                    <div class="row pt-4 border-top border-white border-opacity-10 text-start g-3">
                        <div class="col-6">
                            <small class="text-muted d-block mb-1">Current Read</small>
                            <span class="fw-bold d-block small">The Great Gatsby</span>
                            <div class="progress mt-2" style="height: 4px; background: rgba(255,255,255,0.1);">
                                <div class="progress-bar bg-danger" style="width: 65%;"></div>
                            </div>
                        </div>
                        <div class="col-6 text-end">
                            <small class="text-muted d-block mb-1">Next Due</small>
                            <span class="text-danger fw-bold small">In 2 Days</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>